generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model activity_logs {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    Int?
  action     String   @db.VarChar(50)
  ip_address String   @db.VarChar(45)
  user_agent String?  @db.Text
  details    String?  @db.Text
  created_at DateTime @default(now()) @db.DateTime(0)

  @@index([action], map: "activity_logs_action_index")
  @@index([user_id], map: "activity_logs_user_id_index")
}

model admin_activity_log {
  id          Int       @id @default(autoincrement())
  user_id     Int?
  username    String?   @db.VarChar(50)
  action_type String    @default("") @db.VarChar(30)
  action      String?   @db.VarChar(255)
  page        String?   @db.VarChar(255)
  resource    String?   @db.VarChar(50)
  resource_id Int?
  details     String?   @db.Text
  ip_address  String?   @db.VarChar(45)
  user_agent  String?   @db.Text
  timestamp   DateTime? @default(now()) @db.DateTime(0)
  created_at  DateTime? @default(now()) @db.Timestamp(0)

  @@index([user_id, action_type], map: "user_id")
}

model admin_notifications {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  type       String    @default("info") @db.VarChar(50)
  title      String    @db.VarChar(255)
  message    String?   @db.Text
  is_read    Boolean?  @default(false)
  link       String?   @db.VarChar(255)
  created_at DateTime? @default(now()) @db.DateTime(0)
}

model admin_page_views {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  username   String?   @db.VarChar(50)
  page_name  String?   @db.VarChar(100)
  ip_address String?   @db.VarChar(45)
  user_agent String?   @db.Text
  timestamp  DateTime? @default(now()) @db.DateTime(0)

  @@index([user_id, page_name], map: "user_id")
}

model admin_users {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name              String    @db.VarChar(255)
  email             String    @unique(map: "admin_users_email_unique") @db.VarChar(255)
  password          String    @db.VarChar(255)
  role              String    @default("admin") @db.VarChar(20)
  status            String    @default("active") @db.VarChar(20)
  login_attempts    Int       @default(0)
  last_attempt_time DateTime? @db.DateTime(0)
  last_login        DateTime? @db.DateTime(0)
  created_at        DateTime  @default(now()) @db.DateTime(0)
  updated_at        DateTime  @default(now()) @db.DateTime(0)
}

model blog_categories {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(100)
  slug        String       @unique(map: "slug") @db.VarChar(100)
  description String?      @db.Text
  parent_id   Int?
  created_at  DateTime     @default(now()) @db.DateTime(0)
  updated_at  DateTime     @default(now()) @db.DateTime(0)
  
  posts       blog_posts[]
}

model blog_comments {
  id             Int                  @id @default(autoincrement())
  post_id        Int
  parent_id      Int?
  author_name    String               @db.VarChar(100)
  author_email   String               @db.VarChar(100)
  author_website String?              @db.VarChar(255)
  content        String               @db.Text
  status         blog_comments_status @default(pending)
  ip_address     String?              @db.VarChar(45)
  user_agent     String?              @db.VarChar(255)
  created_at     DateTime             @default(now()) @db.DateTime(0)

  post           blog_posts           @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@index([post_id], map: "post_id")
}

model blog_post_tags {
  post_id Int
  tag_id  Int
  
  post    blog_posts @relation(fields: [post_id], references: [id], onDelete: Cascade)
  tag     blog_tags  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([post_id, tag_id])
}

model blog_posts {
  id               Int               @id @default(autoincrement())
  title            String            @db.VarChar(255)
  slug             String            @unique(map: "slug") @db.VarChar(255)
  excerpt          String?           @db.Text
  content          String            @db.LongText
  image_path       String?           @db.VarChar(255)
  featured         Boolean           @default(false)
  post_type        String?           @db.VarChar(50)
  status           blog_posts_status @default(draft)
  published_at     DateTime?         @db.DateTime(0)
  category_id      Int?
  author_id        Int?
  views            Int               @default(0)
  meta_title       String?           @db.VarChar(255)
  meta_description String?           @db.Text
  meta_keywords    String?           @db.VarChar(255)
  created_at       DateTime          @default(now()) @db.DateTime(0)
  updated_at       DateTime          @default(now()) @db.DateTime(0)
  
  category         blog_categories?          @relation(fields: [category_id], references: [id])
  tags             blog_post_tags[]
  comments         blog_comments[]
  translations     blog_post_translations[]
  
  @@index([category_id], map: "idx_category")
  @@index([status], map: "idx_status")
  @@index([published_at], map: "idx_published")
}

model blog_post_translations {
  id               Int        @id @default(autoincrement())
  post_id          Int
  locale           String     @db.VarChar(5)
  title            String     @db.VarChar(255)
  slug             String     @db.VarChar(255)
  excerpt          String?    @db.Text
  content          String     @db.LongText
  meta_title       String?    @db.VarChar(255)
  meta_description String?    @db.Text
  auto_translated  Boolean    @default(true)
  created_at       DateTime   @default(now()) @db.DateTime(0)
  updated_at       DateTime   @default(now()) @db.DateTime(0)

  post             blog_posts @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([locale, slug], map: "uq_blog_translation_slug")
  @@index([post_id, locale], map: "idx_blog_translation_post_locale")
}

model blog_tags {
  id         Int              @id @default(autoincrement())
  name       String           @db.VarChar(50)
  slug       String           @unique(map: "slug") @db.VarChar(50)
  created_at DateTime         @default(now()) @db.DateTime(0)
  
  posts      blog_post_tags[]
}

model candidates {
  id           Int               @id @default(autoincrement())
  name         String            @db.VarChar(100)
  email        String            @db.VarChar(100)
  phone        String            @db.VarChar(20)
  position     String            @db.VarChar(100)
  job_id       Int?
  resume_path  String            @db.VarChar(255)
  status       candidates_status @default(New)
  submitted_at DateTime          @db.DateTime(0)
  updated_at   DateTime          @default(now()) @db.Timestamp(0)
  notes        String?           @db.Text

  job          job_postings?     @relation(fields: [job_id], references: [id])

  @@index([email], map: "idx_email")
  @@index([status], map: "idx_status")
  @@index([job_id], map: "idx_job_id")
}

model job_postings {
  id              Int                   @id @default(autoincrement())
  title           String                @db.VarChar(200)
  slug            String                @unique @db.VarChar(200)
  department      String                @db.VarChar(100)
  location        String                @db.VarChar(100)
  employment_type String                @db.VarChar(50)
  experience      String?               @db.VarChar(100)
  salary_range    String?               @db.VarChar(100)
  description     String                @db.Text
  requirements    String?               @db.Text
  benefits        String?               @db.Text
  status          job_posting_status    @default(draft)
  featured        Boolean               @default(false)
  applications    Int                   @default(0)
  created_at      DateTime              @default(now()) @db.DateTime(0)
  updated_at      DateTime              @default(now()) @db.Timestamp(0)
  published_at    DateTime?             @db.DateTime(0)

  candidates      candidates[]
  translations    job_posting_translations[]

  @@index([status], map: "idx_job_status")
  @@index([department], map: "idx_department")
}

model job_posting_translations {
  id               Int          @id @default(autoincrement())
  job_id           Int
  locale           String       @db.VarChar(5)
  title            String       @db.VarChar(200)
  slug             String       @db.VarChar(200)
  location         String?      @db.VarChar(100)
  description      String       @db.Text
  requirements     String?      @db.Text
  benefits         String?      @db.Text
  meta_title       String?      @db.VarChar(255)
  meta_description String?      @db.Text
  auto_translated  Boolean      @default(true)
  created_at       DateTime     @default(now()) @db.DateTime(0)
  updated_at       DateTime     @default(now()) @db.DateTime(0)

  job              job_postings @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@unique([locale, slug], map: "uq_job_translation_slug")
  @@index([job_id, locale], map: "idx_job_translation_job_locale")
}

model chat_logs {
  id         Int              @id @default(autoincrement())
  session_id String           @db.VarChar(50)
  message    String           @db.Text
  sender     chat_logs_sender
  agent_id   Int?
  timestamp  DateTime?        @default(now()) @db.DateTime(0)

  @@index([session_id], map: "session_id")
}

model chat_sessions {
  id            Int                   @id @default(autoincrement())
  session_id    String                @db.VarChar(50)
  visitor_ip    String?               @db.VarChar(45)
  visitor_info  String?               @db.Text
  started_at    DateTime?             @default(now()) @db.DateTime(0)
  last_activity DateTime?             @default(now()) @db.DateTime(0)
  status        chat_sessions_status? @default(active)

  @@index([session_id], map: "session_id")
}

model email_templates {
  id            Int       @id @default(autoincrement())
  template_name String    @unique(map: "template_name") @db.VarChar(100)
  subject       String    @db.VarChar(255)
  body          String    @db.Text
  variables     String?   @db.Text
  is_active     Boolean?  @default(true)
  created_at    DateTime? @default(now()) @db.DateTime(0)
  updated_at    DateTime? @db.DateTime(0)
}

model inquiries {
  id                      Int                 @id @default(autoincrement())
  name                    String              @db.VarChar(100)
  email                   String              @db.VarChar(100)
  phone                   String?             @db.VarChar(20)
  company                 String?             @db.VarChar(100)
  form_type               inquiries_form_type
  message                 String              @db.Text
  status                  inquiries_status    @default(New)
  submitted_at            DateTime            @db.DateTime(0)
  updated_at              DateTime            @default(now()) @db.Timestamp(0)
  services                String?             @db.VarChar(255)
  meeting_date            DateTime?           @db.Date
  meeting_time            String?             @db.VarChar(20)
  timezone                String?             @db.VarChar(20)
  service_type            String?             @db.VarChar(100)
  business_industry       String?             @db.VarChar(100)
  implementation_timeline String?             @db.VarChar(50)
  requirements            String?             @db.Text
  additional_comments     String?             @db.Text
  admin_notes             String?             @db.Text
}

model login_logs {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    Int?
  email      String?  @db.VarChar(255)
  ip_address String   @db.VarChar(45)
  user_agent String?  @db.Text
  action     String?  @default("login") @db.VarChar(20)
  success    Boolean  @default(false)
  created_at DateTime @default(now()) @db.DateTime(0)
}

model password_resets {
  id         Int       @id @default(autoincrement())
  email      String    @db.VarChar(100)
  token      String    @db.VarChar(255)
  expires_at DateTime  @db.DateTime(0)
  created_at DateTime? @default(now()) @db.DateTime(0)

  @@index([email, token], map: "email")
}

model permissions {
  id               Int                @id @default(autoincrement())
  name             String             @unique(map: "name") @db.VarChar(50)
  slug             String?            @db.VarChar(50)
  description      String?            @db.Text
  created_at       DateTime?          @default(now()) @db.DateTime(0)
  updated_at       DateTime?          @db.DateTime(0)
  role_permissions role_permissions[]
}

model remember_tokens {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    Int
  selector   String   @unique(map: "selector") @db.VarChar(255)
  token      String   @db.VarChar(255)
  expires    DateTime @db.DateTime(0)
  created_at DateTime @default(now()) @db.DateTime(0)
}

model role_permissions {
  id            Int         @id @default(autoincrement())
  role_id       Int
  permission_id Int
  created_at    DateTime?   @default(now()) @db.DateTime(0)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "role_permissions_ibfk_1")
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "role_permissions_ibfk_2")

  @@unique([role_id, permission_id], map: "role_perm_unique")
  @@index([permission_id], map: "permission_id")
}

model roles {
  id               Int                @id @default(autoincrement())
  name             String             @unique(map: "name") @db.VarChar(50)
  slug             String?            @db.VarChar(50)
  description      String?            @db.Text
  created_at       DateTime?          @default(now()) @db.DateTime(0)
  updated_at       DateTime?          @db.DateTime(0)
  role_permissions role_permissions[]
}

model services {
  id          Int              @id @default(autoincrement())
  name        String           @db.VarChar(255)
  description String?          @db.Text
  icon        String?          @db.VarChar(100)
  status      services_status? @default(active)
  sort_order  Int?             @default(0)
  created_at  DateTime?        @default(now()) @db.DateTime(0)
  updated_at  DateTime?        @db.DateTime(0)
}

model settings {
  id            Int            @id @default(autoincrement())
  setting_group String         @db.VarChar(100)
  setting_key   String         @db.VarChar(100)
  setting_value String?        @db.Text
  type          settings_type? @default(text)
  autoload      Boolean?       @default(true)
  updated_by    Int?
  updated_at    DateTime?      @default(now()) @db.DateTime(0)

  @@unique([setting_group, setting_key], map: "group_key")
}

model solutions {
  id                   Int       @id @default(autoincrement())
  solution_id          String    @unique(map: "solution_id") @db.VarChar(50)
  hero_title           String    @db.Text
  hero_description     String    @db.Text
  hero_image_url       String    @db.VarChar(255)
  intro_text           String    @db.Text
  feature1_title       String    @db.Text
  feature1_description String    @db.Text
  feature1_image_url   String    @db.VarChar(255)
  feature2_title       String    @db.Text
  feature2_features    String    @db.Text
  feature2_image_url   String    @db.VarChar(255)
  feature3_title       String    @db.Text
  feature3_features    String    @db.Text
  feature3_image_url   String    @db.VarChar(255)
  summary_title        String    @db.Text
  summary_text         String    @db.Text
  cta_title            String    @db.Text
  cta_text             String    @db.Text
  cta_button1_text     String    @db.VarChar(100)
  cta_button1_link     String    @db.VarChar(255)
  cta_button2_text     String    @db.VarChar(100)
  cta_button2_link     String    @db.VarChar(255)
  date_created         DateTime? @default(now()) @db.Timestamp(0)
  date_updated         DateTime? @default(now()) @db.Timestamp(0)
}

model user_meta {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    Int
  meta_key   String   @db.VarChar(50)
  meta_value String?  @db.Text
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @db.DateTime(0)

  @@index([meta_key], map: "user_meta_meta_key_index")
  @@index([user_id], map: "user_meta_user_id_foreign")
}

model users {
  id                 Int           @id @default(autoincrement())
  username           String        @unique(map: "username") @db.VarChar(50)
  password           String        @db.VarChar(255)
  email              String        @unique(map: "email") @db.VarChar(100)
  name               String        @db.VarChar(100)
  role               users_role    @default(user)
  avatar             String?       @db.VarChar(255)
  status             users_status? @default(active)
  verification_token String?       @db.VarChar(100)
  email_verified_at  DateTime?     @db.DateTime(0)
  remember_token     String?       @db.VarChar(255)
  token_expiry       DateTime?     @db.DateTime(0)
  login_attempts     Int           @default(0)
  last_attempt_time  DateTime?     @db.DateTime(0)
  last_login         DateTime?     @db.DateTime(0)
  created_at         DateTime?     @default(now()) @db.DateTime(0)
  updated_at         DateTime?     @db.DateTime(0)
}

enum chat_logs_sender {
  visitor
  bot
  agent
}

enum services_status {
  active
  inactive
}

enum settings_type {
  text
  textarea
  boolean
  image
  json
  file
}

enum inquiries_form_type {
  general_inquiry
  meeting_request
  service_intake
}

enum users_role {
  admin
  hr
  marketing
  support
  editor
  author
  user
}

enum candidates_status {
  New
  Under_Review @map("Under Review")
  Shortlisted
  Interviewed
  Offered
  Hired
  Rejected
}

enum job_posting_status {
  draft
  published
  closed
  archived
}

enum chat_sessions_status {
  active
  closed
  transferred
}

enum blog_comments_status {
  pending
  approved
  spam
  trash
}

enum blog_posts_status {
  draft
  pending
  published
  archived
}

enum inquiries_status {
  New
  In_Progress @map("In Progress")
  Replied
  Closed
}

enum users_status {
  active
  inactive
  pending
  blocked
}

enum meeting_booking_status {
  Confirmed
  Completed
  Cancelled
  No_Show @map("No Show")
}

model meeting_availability {
  id          Int      @id @default(autoincrement())
  day_of_week Int      // 0=Sunday .. 6=Saturday
  start_time  String   @db.VarChar(5)  // "09:00" (24h, UAE time)
  end_time    String   @db.VarChar(5)  // "17:00"
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @default(now()) @db.DateTime(0)

  @@unique([day_of_week])
}

model meeting_blocked_dates {
  id           Int      @id @default(autoincrement())
  blocked_date DateTime @db.Date
  reason       String?  @db.VarChar(255)
  created_at   DateTime @default(now()) @db.DateTime(0)

  @@unique([blocked_date])
}

model meeting_bookings {
  id                  Int                    @id @default(autoincrement())
  booking_date        DateTime               @db.Date
  start_time          String                 @db.VarChar(5)
  end_time            String                 @db.VarChar(5)
  visitor_name        String                 @db.VarChar(100)
  visitor_email       String                 @db.VarChar(100)
  visitor_phone       String?                @db.VarChar(20)
  visitor_company     String?                @db.VarChar(100)
  purpose             String?                @db.Text
  visitor_timezone    String                 @db.VarChar(50)
  status              meeting_booking_status @default(Confirmed)
  admin_notes         String?                @db.Text
  cancelled_at        DateTime?              @db.DateTime(0)
  cancellation_reason String?                @db.VarChar(255)
  created_at          DateTime               @default(now()) @db.DateTime(0)
  updated_at          DateTime               @default(now()) @db.DateTime(0)

  @@index([booking_date], map: "idx_booking_date")
  @@index([status], map: "idx_booking_status")
  @@index([visitor_email], map: "idx_visitor_email")
}
